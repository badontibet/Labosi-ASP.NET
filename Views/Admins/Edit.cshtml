@model SystemAdminFormViewModel

@{
    ViewData["Title"] = "Edit System Admin";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="Admins" asp-action="Index">Admins</a>
    <span>/</span>
    <span>Edit @Model.Username</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Restricted CRUD</span>
    <h1>Edit System Admin</h1>
    <p>Update safe operator metadata and server assignments. Stored secrets stay outside this form.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="Admins" asp-action="Edit" asp-route-id="@Model.Id" method="post" data-lab4-form>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <partial name="_AdminForm" model="Model" />
        <div class="form-actions">
            <button type="submit" class="primary-action">Save admin</button>
            <a class="link-chip" asp-controller="Admins" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
