@model List<SystemAdmin>

@{
    ViewData["Title"] = "Admins";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <span>Admins</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Operators</span>
    <h1>System Admin Roster</h1>
    <p>Search, create, and manage operator metadata and NAS server assignments without exposing stored secrets.</p>
    <div class="hero-actions">
        <a class="link-chip" asp-controller="Admins" asp-action="Create">Create admin</a>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert-success">@statusMessage</div>
}

<section class="panel">
    <div class="panel-heading">
        <div>
            <h2>Search Admins</h2>
            <p>Search by username, email, role, or managed server name.</p>
        </div>
        <div class="search-box">
            <label for="admin-search">Search</label>
            <input id="admin-search"
                   class="form-control"
                   type="search"
                   placeholder="Username, email, role, or server..."
                   autocomplete="off"
                   data-lab4-search
                   data-url="@Url.Action("Search", "Admins")"
                   data-target="#admins-table-body"
                   data-loading="#admin-search-loading" />
            <span id="admin-search-loading" class="inline-loading" hidden>Loading...</span>
        </div>
    </div>
    <div class="table-wrap">
        <table data-highlight-id="@TempData["HighlightAdminId"]">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Managed Servers</th>
                    <th>Last Login</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="admins-table-body">
                <partial name="_AdminRows" model="Model" />
            </tbody>
        </table>
    </div>
</section>
