@model DirectoryItemFormViewModel

@{
    ViewData["Title"] = "Create Directory";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="Directories" asp-action="Index">Directories</a>
    <span>/</span>
    <span>Create</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Directory map</span>
    <h1>Create Directory</h1>
    <p>Create directory metadata and optionally connect it to a scan job or parent directory.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="Directories" asp-action="Create" method="post" novalidate data-lab4-form>
        @Html.AntiForgeryToken()
        <partial name="_DirectoryForm" model="Model" />

        <div class="form-actions">
            <button type="submit" class="primary-action">Create</button>
            <a class="link-chip" asp-controller="Directories" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
