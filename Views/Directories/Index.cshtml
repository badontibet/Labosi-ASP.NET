@model List<DirectoryItem>

@{
    ViewData["Title"] = "Directories";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <span>Directories</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Directory map</span>
    <h1>Indexed Directory Hierarchy</h1>
    <p>Root and child directories discovered by mock scan jobs.</p>
</section>

<section class="panel">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Path</th>
                    <th>Parent</th>
                    <th>Files</th>
                    <th>Subdirectories</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var directory in Model)
                {
                    <tr>
                        <td><strong>@directory.Name</strong></td>
                        <td><span class="path-text">@directory.Path</span></td>
                        <td>
                            @if (directory.Parent != null)
                            {
                                <a asp-action="Details" asp-route-id="@directory.ParentId">@directory.Parent.Name</a>
                            }
                            else
                            {
                                <span class="status-badge">Root</span>
                            }
                        </td>
                        <td>@directory.Files.Count</td>
                        <td>@directory.SubDirectories.Count</td>
                        <td><a class="link-chip" asp-action="Details" asp-route-id="@directory.Id">Open directory</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
