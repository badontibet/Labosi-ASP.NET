@model List<DirectoryItem>

@{
    ViewData["Title"] = "Directories";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <span>Directories</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Directory map</span>
    <h1>Indexed Directory Hierarchy</h1>
    <p>Search, create, and manage root and child directories discovered by EF-backed scan jobs.</p>
    <div class="hero-actions">
        <a class="link-chip" asp-controller="Directories" asp-action="Create">Create directory</a>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert-success">@statusMessage</div>
}

<section class="panel">
    <div class="panel-heading">
        <div>
            <h2>Search Directories</h2>
            <p>Search by directory name/path, parent directory, or connected scan job root path.</p>
        </div>
        <div class="search-box">
            <label for="directory-search">Search</label>
            <input id="directory-search"
                   class="form-control"
                   type="search"
                   placeholder="Name, path, parent, or scan root..."
                   autocomplete="off"
                   data-lab4-search
                   data-url="@Url.Action("Search", "Directories")"
                   data-target="#directories-table-body"
                   data-loading="#directory-search-loading" />
            <span id="directory-search-loading" class="inline-loading" hidden>Loading...</span>
        </div>
    </div>
    <div class="table-wrap">
        <table data-highlight-id="@TempData["HighlightDirectoryId"]">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Path</th>
                    <th>Parent</th>
                    <th>Scan Job</th>
                    <th>Files</th>
                    <th>Subdirectories</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="directories-table-body">
                <partial name="_DirectoryRows" model="Model" />
            </tbody>
        </table>
    </div>
</section>
