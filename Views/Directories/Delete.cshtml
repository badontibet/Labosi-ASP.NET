@model DirectoryItem

@{
    ViewData["Title"] = "Delete Directory " + Model.Name;
    var deleteBlocked = ViewData["DeleteBlocked"] as bool? == true;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="Directories" asp-action="Index">Directories</a>
    <span>/</span>
    <span>Delete @Model.Name</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Delete confirmation</span>
    <h1>Delete Directory @Model.Name</h1>
    <p class="path-text">@Model.Path</p>
</section>

<section class="panel delete-panel" data-lab4-delete-panel>
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <dl class="detail-list">
        <dt>Name</dt>
        <dd>@Model.Name</dd>
        <dt>Path</dt>
        <dd><span class="path-text">@Model.Path</span></dd>
        <dt>Child Directories</dt>
        <dd>@Model.SubDirectories.Count</dd>
        <dt>Files</dt>
        <dd>@Model.Files.Count</dd>
    </dl>

    @if (deleteBlocked)
    {
        <div class="alert-danger">
            Delete is blocked because this directory contains child directories or files. Move or delete connected records first.
        </div>
        <div class="form-actions">
            <a class="link-chip" asp-controller="Directories" asp-action="Details" asp-route-id="@Model.Id">Back to details</a>
            <a class="link-chip" asp-controller="Directories" asp-action="Index">Back to list</a>
        </div>
    }
    else
    {
        <form asp-controller="Directories" asp-action="Delete" asp-route-id="@Model.Id" method="post" data-lab4-delete-form data-confirm-message="Delete this directory?">
            @Html.AntiForgeryToken()
            <p class="delete-warning">This action deletes directory metadata. It cannot be undone.</p>
            <div class="form-actions">
                <button type="submit" class="danger-action">Delete directory</button>
                <a class="link-chip" asp-controller="Directories" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
