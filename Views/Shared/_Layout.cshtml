<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NAS Indexer</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="side-rail">
            <a class="brand-lockup" asp-controller="Home" asp-action="Index" aria-label="NAS Indexer dashboard">
                <span class="brand-mark">NI</span>
                <span>
                    <strong>NAS Indexer</strong>
                    <small>Ops console</small>
                </span>
            </a>

            <nav class="primary-nav" aria-label="Primary navigation">
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="NasServers" asp-action="Index">NAS Servers</a>
                <a asp-controller="ScanJobs" asp-action="Index">Scan Jobs</a>
                <a asp-controller="Directories" asp-action="Index">Directories</a>
                <a asp-controller="FileItems" asp-action="Index">Files</a>
                <a asp-controller="Tags" asp-action="Index">Tags</a>
                <a asp-controller="Admins" asp-action="Index">Admins</a>
            </nav>

            <div class="rail-note">
                <span class="pulse-dot"></span>
                EF SQLite repository feed
            </div>
        </aside>

        <main class="content-deck">
            @RenderBody()
        </main>
    </div>
</body>
</html>
