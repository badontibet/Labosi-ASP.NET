@model ScanJobFormViewModel

@{
    ViewData["Title"] = "Edit Scan Job " + Model.Id;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="ScanJobs" asp-action="Index">Scan Jobs</a>
    <span>/</span>
    <span>Edit Job @Model.Id</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Scan job metadata</span>
    <h1>Edit Job @Model.Id</h1>
    <p>Update scan metadata without changing scanned directory or file history.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="ScanJobs" asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate data-lab4-form>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <partial name="_ScanJobForm" model="Model" />

        <div class="form-actions">
            <button type="submit" class="primary-action">Save changes</button>
            <a class="link-chip" asp-controller="ScanJobs" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
