@model ScanJobFormViewModel

@{
    ViewData["Title"] = "Create Scan Job";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="ScanJobs" asp-action="Index">Scan Jobs</a>
    <span>/</span>
    <span>Create</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Scan job setup</span>
    <h1>Create Scan Job</h1>
    <p>Create scan metadata with server-side validation, text-based date-time entry, and reusable NAS server autocomplete.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="ScanJobs" asp-action="Create" method="post" novalidate data-lab4-form>
        @Html.AntiForgeryToken()
        <partial name="_ScanJobForm" model="Model" />

        <div class="form-actions">
            <button type="submit" class="primary-action">Create</button>
            <a class="link-chip" asp-controller="ScanJobs" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
