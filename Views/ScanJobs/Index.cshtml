@model List<ScanJob>

@{
    ViewData["Title"] = "Scan Jobs";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <span>Scan Jobs</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Scan telemetry</span>
    <h1>Scan Job Timeline</h1>
    <p>Search scan jobs, review processing progress, and manage scan metadata.</p>
    <div class="hero-actions">
        <a class="link-chip" asp-controller="ScanJobs" asp-action="Create">Create scan job</a>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert-success">@statusMessage</div>
}

<section class="panel">
    <div class="panel-heading">
        <div>
            <h2>Search Scan Jobs</h2>
            <p>Search by NAS server name, root path, or status. Results update without a full page reload.</p>
        </div>
        <div class="search-box">
            <label for="scan-job-search">Search</label>
            <input id="scan-job-search"
                   class="form-control"
                   type="search"
                   placeholder="Server, root path, or status..."
                   autocomplete="off"
                   data-lab4-search
                   data-url="@Url.Action("Search", "ScanJobs")"
                   data-target="#scan-jobs-table-body"
                   data-loading="#scan-job-search-loading" />
            <span id="scan-job-search-loading" class="inline-loading" hidden>Loading...</span>
        </div>
    </div>
    <div class="table-wrap">
        <table data-highlight-id="@TempData["HighlightScanJobId"]">
            <thead>
                <tr>
                    <th>Job</th>
                    <th>Server</th>
                    <th>Status</th>
                    <th>Root Path</th>
                    <th>Progress</th>
                    <th>Started</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="scan-jobs-table-body">
                <partial name="_ScanJobRows" model="Model" />
            </tbody>
        </table>
    </div>
</section>
