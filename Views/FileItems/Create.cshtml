@model FileItemFormViewModel

@{
    ViewData["Title"] = "Create File";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="FileItems" asp-action="Index">Files</a>
    <span>/</span>
    <span>Create</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">File metadata</span>
    <h1>Create File</h1>
    <p>Create file metadata, assign a directory, and optionally connect tags.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="FileItems" asp-action="Create" method="post" novalidate data-lab4-form>
        @Html.AntiForgeryToken()
        <partial name="_FileForm" model="Model" />

        <div class="form-actions">
            <button type="submit" class="primary-action">Create</button>
            <a class="link-chip" asp-controller="FileItems" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
