@model FileItem

@{
    ViewData["Title"] = "Delete File " + Model.Name;
    var deleteBlocked = ViewData["DeleteBlocked"] as bool? == true;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="FileItems" asp-action="Index">Files</a>
    <span>/</span>
    <span>Delete @Model.Name</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Delete confirmation</span>
    <h1>Delete File @Model.Name</h1>
    <p class="path-text">@Model.Path</p>
</section>

<section class="panel delete-panel" data-lab4-delete-panel>
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <dl class="detail-list">
        <dt>Name</dt>
        <dd>@Model.Name</dd>
        <dt>Directory</dt>
        <dd>@Model.Directory.Name</dd>
        <dt>Tags</dt>
        <dd>@Model.Tags.Count</dd>
        <dt>Change Logs</dt>
        <dd>@Model.ChangeLogs.Count</dd>
    </dl>

    @if (deleteBlocked)
    {
        <div class="alert-danger">
            Delete is blocked because this file has change log entries. File history must remain read-only.
        </div>
        <div class="form-actions">
            <a class="link-chip" asp-controller="FileItems" asp-action="Details" asp-route-id="@Model.Id">Back to details</a>
            <a class="link-chip" asp-controller="FileItems" asp-action="Index">Back to list</a>
        </div>
    }
    else
    {
        <form asp-controller="FileItems" asp-action="Delete" asp-route-id="@Model.Id" method="post" data-lab4-delete-form data-confirm-message="Delete this file metadata?">
            @Html.AntiForgeryToken()
            <p class="delete-warning">This action deletes file metadata. It cannot be undone.</p>
            <div class="form-actions">
                <button type="submit" class="danger-action">Delete file</button>
                <a class="link-chip" asp-controller="FileItems" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
