@model List<FileItem>

@{
    ViewData["Title"] = "Files";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <span>Files</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">File intelligence</span>
    <h1>Indexed File Catalog</h1>
    <p>Search, create, and manage metadata, directory placement, tags, and change counts for indexed files.</p>
    <div class="hero-actions">
        <a class="link-chip" asp-controller="FileItems" asp-action="Create">Create file</a>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert-success">@statusMessage</div>
}

<section class="panel">
    <div class="panel-heading">
        <div>
            <h2>Search Files</h2>
            <p>Search by file name, path, extension, directory, or tag.</p>
        </div>
        <div class="search-box">
            <label for="file-search">Search</label>
            <input id="file-search"
                   class="form-control"
                   type="search"
                   placeholder="Name, path, extension, directory, or tag..."
                   autocomplete="off"
                   data-lab4-search
                   data-url="@Url.Action("Search", "FileItems")"
                   data-target="#files-table-body"
                   data-loading="#file-search-loading" />
            <span id="file-search-loading" class="inline-loading" hidden>Loading...</span>
        </div>
    </div>
    <div class="table-wrap">
        <table data-highlight-id="@TempData["HighlightFileId"]">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Size</th>
                    <th>Modified</th>
                    <th>Directory</th>
                    <th>Signals</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="files-table-body">
                <partial name="_FileRows" model="Model" />
            </tbody>
        </table>
    </div>
</section>
