@model FileTag

@{
    ViewData["Title"] = "Delete Tag " + Model.Name;
    var deleteBlocked = ViewData["DeleteBlocked"] as bool? == true;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="Tags" asp-action="Index">Tags</a>
    <span>/</span>
    <span>Delete @Model.Name</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Delete confirmation</span>
    <h1>Delete Tag <span class="tag-chip">@Model.Name</span></h1>
    <p>Confirm deletion only when this tag is not assigned to any indexed file.</p>
</section>

<section class="panel delete-panel" data-lab4-delete-panel>
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <dl class="detail-list">
        <dt>Name</dt>
        <dd>@Model.Name</dd>
        <dt>Description</dt>
        <dd>@Model.Description</dd>
        <dt>Color</dt>
        <dd><span class="swatch" style="background-color:@Model.Color"></span> @Model.Color</dd>
        <dt>Tagged Files</dt>
        <dd>@Model.Files.Count</dd>
    </dl>

    @if (deleteBlocked)
    {
        <div class="alert-danger">
            Delete is blocked because this tag is assigned to one or more files. Remove tag assignments before deleting it.
        </div>
        <div class="form-actions">
            <a class="link-chip" asp-controller="Tags" asp-action="Details" asp-route-id="@Model.Id">Back to details</a>
            <a class="link-chip" asp-controller="Tags" asp-action="Index">Back to list</a>
        </div>
    }
    else
    {
        <form asp-controller="Tags" asp-action="Delete" asp-route-id="@Model.Id" method="post" data-lab4-delete-form data-confirm-message="Delete this tag?">
            @Html.AntiForgeryToken()
            <p class="delete-warning">This action deletes the tag metadata. It cannot be undone.</p>
            <div class="form-actions">
                <button type="submit" class="danger-action">Delete tag</button>
                <a class="link-chip" asp-controller="Tags" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
