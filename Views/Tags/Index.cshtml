@model List<FileTag>

@{
    ViewData["Title"] = "Tags";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <span>Tags</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Classification</span>
    <h1>File Tag Registry</h1>
    <p>Read-only labels connected to indexed files.</p>
</section>

<section class="panel">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Color</th>
                    <th>Files</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model)
                {
                    <tr>
                        <td><span class="tag-chip">@tag.Name</span></td>
                        <td>@tag.Description</td>
                        <td><span class="swatch" style="background-color:@tag.Color"></span> @tag.Color</td>
                        <td>@tag.Files.Count</td>
                        <td><a class="link-chip" asp-action="Details" asp-route-id="@tag.Id">Open tag</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
