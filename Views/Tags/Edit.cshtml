@model FileTagFormViewModel

@{
    ViewData["Title"] = "Edit Tag " + Model.Name;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="Tags" asp-action="Index">Tags</a>
    <span>/</span>
    <span>Edit @Model.Name</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Classification</span>
    <h1>Edit File Tag</h1>
    <p>Update tag metadata without changing the files currently assigned to it.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="Tags" asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate data-lab4-form>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <partial name="_TagForm" model="Model" />

        <div class="form-actions">
            <button type="submit" class="primary-action">Save changes</button>
            <a class="link-chip" asp-controller="Tags" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
