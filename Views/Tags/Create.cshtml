@model FileTagFormViewModel

@{
    ViewData["Title"] = "Create Tag";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="Tags" asp-action="Index">Tags</a>
    <span>/</span>
    <span>Create</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Classification</span>
    <h1>Create File Tag</h1>
    <p>Create a reusable label for indexed files.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="Tags" asp-action="Create" method="post" novalidate data-lab4-form>
        @Html.AntiForgeryToken()
        <partial name="_TagForm" model="Model" />

        <div class="form-actions">
            <button type="submit" class="primary-action">Create</button>
            <a class="link-chip" asp-controller="Tags" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
