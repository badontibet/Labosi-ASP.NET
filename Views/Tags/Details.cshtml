@model FileTag

@{
    ViewData["Title"] = Model.Name;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="Tags" asp-action="Index">Tags</a>
    <span>/</span>
    <span>@Model.Name</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Tag details</span>
    <h1><span class="tag-chip">@Model.Name</span></h1>
    <p>@Model.Description</p>
    <div class="hero-actions">
        <a class="link-chip" asp-controller="Tags" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="link-chip link-danger" asp-controller="Tags" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
        <a class="link-chip" asp-controller="Tags" asp-action="Index">Back to tags</a>
    </div>
</section>

<section class="metadata-grid">
    <article class="metadata-card"><span>Color</span><strong><span class="swatch" style="background-color:@Model.Color"></span> @Model.Color</strong></article>
    <article class="metadata-card"><span>Tagged Files</span><strong>@Model.Files.Count</strong></article>
</section>

<section class="panel">
    <h3>Files</h3>
    @if (Model.Files.Any())
    {
        <ul class="file-list">
            @foreach (var file in Model.Files)
            {
                <li>
                    <a asp-controller="FileItems" asp-action="Details" asp-route-id="@file.Id">@file.Name</a>
                    <span class="path-text">@file.Path</span>
                </li>
            }
        </ul>
    }
    else
    {
        <p>No files use this tag.</p>
    }
</section>
