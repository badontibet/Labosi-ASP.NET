@model NasServerFormViewModel

@{
    ViewData["Title"] = "Create NAS Server";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="NasServers" asp-action="Index">NAS Servers</a>
    <span>/</span>
    <span>Create</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Restricted CRUD</span>
    <h1>Create NAS Server</h1>
    <p>Add editable server metadata while keeping stored secrets outside this workflow.</p>
</section>

<section class="panel form-panel">
    <form asp-controller="NasServers" asp-action="Create" method="post" data-lab4-form>
        @Html.AntiForgeryToken()
        <partial name="_NasServerForm" model="Model" />
        <div class="form-actions">
            <button type="submit" class="primary-action">Create server</button>
            <a class="link-chip" asp-controller="NasServers" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
