@model NasServer

@{
    ViewData["Title"] = Model.Name;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="NasServers" asp-action="Index">NAS Servers</a>
    <span>/</span>
    <span>@Model.Name</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Server details</span>
    <h1>@Model.Name</h1>
    @if (Model.IsActive)
    {
        <span class="status-badge status-good">Active</span>
    }
    else
    {
        <span class="status-badge status-bad">Inactive</span>
    }
    <div class="hero-actions">
        <a class="link-chip" asp-controller="NasServers" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="link-chip link-danger" asp-controller="NasServers" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
        <a class="link-chip" asp-controller="NasServers" asp-action="Index">Back to servers</a>
    </div>
</section>

<section class="metadata-grid">
    <article class="metadata-card"><span>Address</span><strong>@Model.IpAddress:@Model.Port</strong></article>
    <article class="metadata-card"><span>Username</span><strong>@(string.IsNullOrWhiteSpace(Model.Username) ? "Not set" : Model.Username)</strong></article>
    <article class="metadata-card"><span>Last Scan</span><strong>@Model.LastScan.ToString("yyyy-MM-dd HH:mm")</strong></article>
    <article class="metadata-card"><span>Scan Jobs</span><strong>@Model.ScanJobs.Count</strong></article>
    <article class="metadata-card"><span>Managed Admins</span><strong>@Model.ManagedAdmins.Count</strong></article>
    <article class="metadata-card"><span>Stored Secret</span><strong>Protected outside normal CRUD</strong></article>
</section>

<section class="panel">
    <h3>Scan Jobs</h3>
    @if (Model.ScanJobs.Any())
    {
        <ul class="timeline-list">
            @foreach (var job in Model.ScanJobs)
            {
                <li>
                    <partial name="_ScanStatusBadge" model="job.Status" />
                    <a asp-controller="ScanJobs" asp-action="Details" asp-route-id="@job.Id">Job @job.Id</a>
                    <span class="path-text">@job.RootPath</span>
                    <span class="muted">@job.ProcessedFiles / @job.TotalFiles files</span>
                </li>
            }
        </ul>
    }
    else
    {
        <p>No scan jobs have been recorded for this server.</p>
    }
</section>

<section class="panel">
    <h3>Root Directories</h3>
    @if (Model.ScanJobs.Any(job => job.ScannedDirectories.Any()))
    {
        <ul class="tree-list">
            @foreach (var job in Model.ScanJobs)
            {
                @foreach (var directory in job.ScannedDirectories)
                {
                    <li>
                        <a asp-controller="Directories" asp-action="Details" asp-route-id="@directory.Id">@directory.Path</a>
                        <span class="muted">from Job @job.Id</span>
                    </li>
                }
            }
        </ul>
    }
    else
    {
        <p>No root directories are connected to this server's scan jobs.</p>
    }
</section>
