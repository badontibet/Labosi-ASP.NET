@model NasServer

@{
    ViewData["Title"] = "Delete NAS Server " + Model.Name;
    var deleteBlocked = ViewData["DeleteBlocked"] as bool? == true;
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-controller="NasServers" asp-action="Index">NAS Servers</a>
    <span>/</span>
    <span>Delete @Model.Name</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Delete confirmation</span>
    <h1>Delete NAS Server @Model.Name</h1>
    <p>Deletion is allowed only when the server has no scan jobs and no assigned administrators.</p>
</section>

<section class="panel delete-panel" data-lab4-delete-panel>
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <dl class="detail-list">
        <dt>Name</dt>
        <dd>@Model.Name</dd>
        <dt>Address</dt>
        <dd>@Model.IpAddress:@Model.Port</dd>
        <dt>Status</dt>
        <dd>@(Model.IsActive ? "Active" : "Inactive")</dd>
        <dt>Scan Jobs</dt>
        <dd>@Model.ScanJobs.Count</dd>
        <dt>Managed Admins</dt>
        <dd>@Model.ManagedAdmins.Count</dd>
    </dl>

    @if (deleteBlocked)
    {
        <div class="alert-danger">
            Delete is blocked because this NAS server has scan jobs or assigned administrators.
        </div>
        <div class="form-actions">
            <a class="link-chip" asp-controller="NasServers" asp-action="Details" asp-route-id="@Model.Id">Back to details</a>
            <a class="link-chip" asp-controller="NasServers" asp-action="Index">Back to list</a>
        </div>
    }
    else
    {
        <form asp-controller="NasServers" asp-action="Delete" asp-route-id="@Model.Id" method="post" data-lab4-delete-form data-confirm-message="Delete this NAS server?">
            @Html.AntiForgeryToken()
            <p class="delete-warning">This action deletes the server metadata only. It cannot be undone.</p>
            <div class="form-actions">
                <button type="submit" class="danger-action">Delete server</button>
                <a class="link-chip" asp-controller="NasServers" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </div>
        </form>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
