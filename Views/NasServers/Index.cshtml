@model List<NasServer>

@{
    ViewData["Title"] = "NAS Servers";
}

<nav class="breadcrumb" aria-label="Breadcrumb">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <span>NAS Servers</span>
</nav>

<section class="page-hero">
    <span class="eyebrow">Server inventory</span>
    <h1>NAS Server Grid</h1>
    <p>Search, create, and manage NAS endpoint metadata while stored secrets stay outside this UI.</p>
    <div class="hero-actions">
        <a class="link-chip" asp-controller="NasServers" asp-action="Create">Create server</a>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert-success">@statusMessage</div>
}

<section class="panel">
    <div class="panel-heading">
        <div>
            <h2>Search NAS Servers</h2>
            <p>Search by name, IP address, port, username, status, or scan root path.</p>
        </div>
        <div class="search-box">
            <label for="server-search">Search</label>
            <input id="server-search"
                   class="form-control"
                   type="search"
                   placeholder="Name, IP, port, status, or root path..."
                   autocomplete="off"
                   data-lab4-search
                   data-url="@Url.Action("Search", "NasServers")"
                   data-target="#servers-table-body"
                   data-loading="#server-search-loading" />
            <span id="server-search-loading" class="inline-loading" hidden>Loading...</span>
        </div>
    </div>
    <div class="table-wrap">
        <table data-highlight-id="@TempData["HighlightNasServerId"]">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Network</th>
                    <th>Status</th>
                    <th>Last Scan</th>
                    <th>Username</th>
                    <th>Relations</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="servers-table-body">
                <partial name="_NasServerRows" model="Model" />
            </tbody>
        </table>
    </div>
</section>
